<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/SecureEnvelopeKit/SecureEnvelopeKit.csproj" />
  </ItemGroup>

  <!-- Link the shared, repository-root fixture into the test output as the single source of truth. -->
  <ItemGroup>
    <None Include="$(MSBuildThisFileDirectory)../../../../fixtures/SecureEnvelopeV1/secure-envelope-v1.json"
          Link="Fixtures/secure-envelope-v1.json"
          CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
